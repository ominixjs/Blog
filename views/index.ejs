<%- include('layouts/head') %> <%- include('layouts/navbar') %>
<section class="container">

    <!-- Layout Principal -->
    <div class="blog-layout">
        <!-- Posts Section -->
        <div class="posts-grid">
            <% articles.splice(0, 1).forEach(article => { %>
                 <!-- Post Destacado -->
            <article class="post-card featured-post">
                <div class="image-container">
                    <img
                        class="post-image"
                        src="https://picsum.photos/id/104/800/600"
                        alt="Postagem destacada"
                    />
                    <div class="post-badge">⭐ Destacado</div>
                </div>
                <div class="post-content">
                    <div class="post-date">
                        <span class="date-icon">📅</span>
                        <span><%= formatDateTime(article.createdAt) %></span>
                    </div>
                    <h2 class="post-title">
                        <a href="/<%- article.slug %>"
                            ><%= article.title %></a
                        >
                    </h2>
                    <p class="post-excerpt">
                        Estudos mostram que passar tempo em contato com a natureza pode reduzir o estresse, melhorar o humor e aumentar a criatividade. Saiba como incorporar mais verde na sua rotina diária...
                    </p>
                    <a href="/<%- article.slug %>" class="read-more">Leia mais</a>
                </div>
            </article>

            <% }) %>
            <% articles.splice(1).forEach(article => { %>
           
            <!-- Post 1 -->
            <article class="post-card">
                <div class="image-container">
                    <img
                        class="post-image"
                        src="https://picsum.photos/id/1/400/300"
                        alt="Natureza"
                    />
                </div>
                <div class="post-content">
                    <div class="post-date">
                        <span class="date-icon">📅</span>
                        <span>1<%= formatDateTime(article.createdAt) %></span>
                    </div>
                    <h2 class="post-title">
                        <a href="/<%- article.slug %>"
                            ><%= article.title %></a
                        >
                    </h2>
                    <p class="post-excerpt">
                        Estudos mostram que passar tempo em contato com a
                        natureza pode reduzir o estresse, melhorar o humor e
                        aumentar a criatividade. Saiba como incorporar mais
                        verde na sua rotina diária...
                    </p>
                    <a href="/<%- article.slug %>" class="read-more">Leia mais</a>
                </div>
            </article>

            <% }) %>
        </div>

        <!-- Sidebar -->
        <aside class="sidebar">
            <h3>📌 Sobre o Blog</h3>
            <p style="color: #666; line-height: 1.6; margin-bottom: 20px">
                Um espaço dedicado a compartilhar conhecimento, experiências e
                inspirações sobre tecnologia, viagens, produtividade e estilo de
                vida.
            </p>

            <h3>📚 Categorias</h3>
            <ul>
                 <% categories.splice(1).forEach(category => { %>
                    <li><a href="/category">📚 <%= category.title %></a></li>
                 <% }) %>
              
            </ul>

            <h3>🏷️ Tags Populares</h3>
            <ul>
                <li><a href="#">#Programação</a></li>
            </ul>
        </aside>
    </div>
</section>
<%- include('layouts/footer') %>
