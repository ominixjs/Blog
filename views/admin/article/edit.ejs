<%- include('../../layouts/head') %> <%- include('../../layouts/navbar') %>
<section class="container">
    <div class="form-header">
        <div>
            <h1>📝 Edite artigo</h1>
            <p>Crie aqui seu artigo</p>
        </div>
    </div>

    <div class="form-body">
        <form action="/article/update" method="post" id="contentForm">
            <input type="hidden" name="id" value="<%= id %>" />

            <div class="form-group">
                <label for="title"> <i>📌</i> Título do Conteúdo </label>
                <input
                    type="text"
                    id="title"
                    name="title"
                    placeholder="Digite um título atraente para seu conteúdo..."
                    value="<%= title %>"
                    required
                />
            </div>

            <div class="form-group">
                <label for="slug">Slug</label>
                <input
                    type="text"
                    id="slug"
                    name="slug"
                    placeholder="exemplo-de-slug"
                    value="<%= slug %>"
                    disabled
                />
            </div>

            <div class="custom-select">
                <label>📌 Select básico</label>
                <select name="category">
                    <option value="">Selecione uma opção</option>
                    <% categories.forEach(category => {%>
                        <% if (category.id == categoryId) { %>
                            <option value="<%= category.id %>" selected><%= category.title %></option>
                            <% return %>
                        <% } %>
                        <option value="<%= category.id %>"><%= category.title %></option>
                    <%})%>
                </select>
                <div class="arrow">▼</div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="createdAt">Data de Criação</label>
                    <input
                        type="text"
                        id="createdAt"
                        name="createdAt"
                        value="<%= formatDateTime(created) %>"
                        disabled
                    />
                </div>

                <div class="form-group">
                    <label for="updatedAt">Última Modificação</label>
                    <input
                        type="text"
                        id="updatedAt"
                        name="updatedAt"
                        value="<%= formatDateTime(updated) %>"
                        disabled
                    />
                </div>
            </div>

            <div class="form-group">
                <label> <i>✏️</i> Conteúdo Principal </label>
                <div class="editor" id="editor" style="height: 600px">
                    <%- body %>
                </div>
                <input type="hidden" name="content" id="content" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    💾 Salvar Conteúdo
                </button>
                <a href="/admin/articles" class="btn btn-secondary">
                    ❌ Cancelar
                </a>
                <button type="button" id="clearBtn" class="btn btn-outline">
                    🗑️ Limpar
                </button>
                <button type="button" id="previewBtn" class="btn btn-secondary">
                    👁️ Visualizar
                </button>
            </div>
        </form>

        <div id="previewSection" class="preview-section">
            <h3 class="preview-title" id="previewTitle"></h3>
            <div class="preview-content" id="previewContent"></div>
            <button
                type="button"
                id="closePreview"
                class="btn btn-outline"
                style="margin-top: 15px"
            >
                Fechar Preview
            </button>
        </div>
    </div>
</section>
<%- include('../../layouts/footer') %>
