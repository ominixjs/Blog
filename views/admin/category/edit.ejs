<%- include('../../partials/head') %> <%- include('../../partials/navbar-admin')
%>
<section class="container">
    <div class="form-container">
        <div class="form-header">
            <div>
                <h1>📝 Editar categoria</h1>
                <p>Atualize as informações do seu conteúdo</p>
            </div>
        </div>

        <div class="form-body">
            <form action="/category/update" method="post" id="contentForm">
                <input type="hidden" name="id" value="<%= id %>" />

                <!-- Título -->
                <div class="form-group">
                    <label>📌 Título</label>
                    <input
                        type="text"
                        name="title"
                        value="<%= title %>"
                        placeholder="Digite um título atrativo..."
                        required
                    />
                </div>

                <!-- Slug -->
                <div class="form-group">
                    <label>🔗 Slug</label>
                    <input
                        type="text"
                        name="slug"
                        value="<%= slug %>"
                        disabled
                    />
                </div>

                <!-- Datas -->
                <div class="form-row">
                    <div class="form-group">
                        <label>📅 Criado em</label>
                        <input
                            value="<%= formatDateTime(created) %>"
                            disabled
                        />
                    </div>

                    <div class="form-group">
                        <label>🕒 Atualizado em</label>
                        <input
                            value="<%= formatDateTime(updated) %>"
                            disabled
                        />
                    </div>
                </div>

                <!-- Ações -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        💾 Salvar
                    </button>

                    <a href="/admin/categories" class="btn btn-secondary">
                        Cancelar
                    </a>

                    <button type="button" id="clearBtn" class="btn btn-outline">
                        Limpar
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

<%- include('../../partials/footer') %>
